# Formas de Conex„o

# Conex„o com Windows Authentication
# CONNECTION_STRING=Server=NOME_DO_SERVIDOR;Database=NOME_DO_BANCO;Trusted_Connection=True;TrustServerCertificate=True

# Conex„o com SQL Server Authentication
# CONNECTION_STRING=Server=NOME_DO_SERVIDOR;Database=NOME_DO_BANCO;User Id=SEU_USUARIO;Password=SUA_SENHA;TrustServerCertificate=True

# JWT_KEY deve conter exatamente 32 caracteres para garantir a seguranÁa adequada. Certifique-se de usar uma chave forte e ˙nica para proteger seus tokens JWT.
# JWT_KEY=sua_chave_jwt